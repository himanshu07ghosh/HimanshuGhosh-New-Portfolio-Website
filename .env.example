# Copy this file to .env.local and fill in your own values.
# The contact form works without these (it falls back to opening
# the visitor's email client), but configure them for automatic sending.

# --- EmailJS (https://www.emailjs.com) ---
# Free tier is enough for a portfolio contact form.
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=

# --- Google Sheets logging (optional) ---
# Paste the deployed Google Apps Script Web App URL here.
# See README.md "Contact form setup" for step-by-step instructions.
NEXT_PUBLIC_GOOGLE_SHEETS_WEBHOOK_URL=
